{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": [
      "jest"
    ],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ui": [
        "./src/shared/ui/index"
      ]
    },
    "verbatimModuleSyntax": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods"
  ]
}